FIREBASE_PROJECT_ID={{ librechat_firebase_project_id }}
FIREBASE_STORAGE_BUCKET={{ librechat_firebase_storage_bucket }}
FIREBASE_MESSAGING_SENDER_ID={{ librechat_firebase_messaging_sender_id }}
FIREBASE_APP_ID={{ librechat_firebase_app_id }}

##########################
#  S3 AWS Bucket         #
##########################

AWS_ENDPOINT_URL={{ librechat_aws_endpoint_url }}
AWS_ACCESS_KEY_ID={{ librechat_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ librechat_aws_secret_access_key }}
AWS_REGION={{ librechat_aws_region }}
AWS_BUCKET_NAME={{ librechat_aws_bucket_name }}
# Required for path-style S3-compatible providers (MinIO, Hetzner, Backblaze B2, etc.)
AWS_FORCE_PATH_STYLE={{ librechat_aws_force_path_style }}

##########################
#  Azure Blob Storage    #
##########################

AZURE_STORAGE_CONNECTION_STRING={{ librechat_azure_storage_connection_string }}
AZURE_STORAGE_PUBLIC_ACCESS={{ librechat_azure_storage_public_access }}
AZURE_CONTAINER_NAME={{ librechat_azure_container_name }}

##########################
# Shared Links           #
##########################

ALLOW_SHARED_LINKS={{ librechat_allow_shared_links }}
ALLOW_SHARED_LINKS_PUBLIC={{ librechat_allow_shared_links_public }}

################################
# Static File Cache Control    #
################################

# Leave commented out to use defaults: 1 day (86400 seconds) for s-maxage and 2 days (172800 seconds) for max-age
# NODE_ENV must be set to production for these to take effect
STATIC_CACHE_MAX_AGE={{ librechat_static_cache_max_age }}
STATIC_CACHE_S_MAX_AGE={{ librechat_static_cache_s_max_age }}

# If you have another service in front of your LibreChat doing compression, disable express based compression here
DISABLE_COMPRESSION={{ librechat_disable_compression }}

# Enable gzip scan/serving of pre-gzipped uploaded images
ENABLE_IMAGE_OUTPUT_GZIP_SCAN={{ librechat_enable_image_output_gzip_scan }}

# Conversation import file size limit (bytes)
{% if librechat_conversation_import_max_file_size_bytes is not none %}CONVERSATION_IMPORT_MAX_FILE_SIZE_BYTES={{ librechat_conversation_import_max_file_size_bytes }}{% endif %}

#####################################################
#                        UI                         #
#####################################################

APP_TITLE={{ librechat_app_title }}
CUSTOM_FOOTER={{ librechat_custom_footer }}
HELP_AND_FAQ_URL={{ librechat_help_and_faq_url }}

SHOW_BIRTHDAY_ICON={{ librechat_show_birthday_icon }}

# Google tag manager id
# ANALYTICS_GTM_ID={{ librechat_analytics_gtm_id }}

#####################################################
#                  Cache Headers                    #
#####################################################
# Headers controlling caching of index.html. Leave blank for safe defaults
# (no-cache, no-store, must-revalidate). NODE_ENV must be production.

INDEX_CACHE_CONTROL={{ librechat_index_cache_control }}
INDEX_PRAGMA={{ librechat_index_pragma }}
INDEX_EXPIRES={{ librechat_index_expires }}

#####################################################
#                       Redis                       #
#####################################################
# Caching, sessions, resumable streams, multi-instance leader election.
#
# IMPORTANT: REDIS_URI must be omitted entirely (not REDIS_URI=) when Redis
# is not used. LibreChat's redisClients.ts does:
#   cacheConfig.REDIS_URI?.split(',').map((uri) => new URL(uri))
# The `?.` only short-circuits on undefined/null. An empty string would
# pass through and crash startup with `new URL('')` -> ERR_INVALID_URL.
{% if librechat_redis_uri %}
USE_REDIS={{ librechat_use_redis }}
USE_REDIS_STREAMS={{ librechat_use_redis_streams }}
REDIS_URI={{ librechat_redis_uri }}
REDIS_CA={{ librechat_redis_ca }}
REDIS_USE_ALTERNATIVE_DNS_LOOKUP={{ librechat_redis_use_alternative_dns_lookup }}
REDIS_USERNAME={{ librechat_redis_username }}
REDIS_PASSWORD={{ librechat_redis_password }}
REDIS_KEY_PREFIX_VAR={{ librechat_redis_key_prefix_var }}
REDIS_KEY_PREFIX={{ librechat_redis_key_prefix }}
REDIS_MAX_LISTENERS={{ librechat_redis_max_listeners }}
REDIS_PING_INTERVAL={{ librechat_redis_ping_interval }}
FORCED_IN_MEMORY_CACHE_NAMESPACES={{ librechat_forced_in_memory_cache_namespaces }}

# Leader election (multi-instance)
LEADER_LEASE_DURATION={{ librechat_leader_lease_duration }}
LEADER_RENEW_INTERVAL={{ librechat_leader_renew_interval }}
LEADER_RENEW_ATTEMPTS={{ librechat_leader_renew_attempts }}
LEADER_RENEW_RETRY_DELAY={{ librechat_leader_renew_retry_delay }}
{% else %}
# Redis disabled (no librechat_redis_uri set).
# Set librechat_use_redis: true and librechat_redis_uri: redis://... in inventory to enable.
# USE_REDIS=
# REDIS_URI=
{% endif %}

#####################################################
#                MCP Configuration                  #
#####################################################

{% if librechat_mcp_oauth_on_auth_error is not none %}MCP_OAUTH_ON_AUTH_ERROR={{ librechat_mcp_oauth_on_auth_error }}{% endif %}
{% if librechat_mcp_oauth_detection_timeout is not none %}MCP_OAUTH_DETECTION_TIMEOUT={{ librechat_mcp_oauth_detection_timeout }}{% endif %}
{% if librechat_mcp_connection_check_ttl is not none %}MCP_CONNECTION_CHECK_TTL={{ librechat_mcp_connection_check_ttl }}{% endif %}
{% if librechat_mcp_skip_code_challenge_check is not none %}MCP_SKIP_CODE_CHALLENGE_CHECK={{ librechat_mcp_skip_code_challenge_check }}{% endif %}

# Circuit breaker
{% if librechat_mcp_cb_max_cycles is not none %}MCP_CB_MAX_CYCLES={{ librechat_mcp_cb_max_cycles }}{% endif %}
{% if librechat_mcp_cb_cycle_window_ms is not none %}MCP_CB_CYCLE_WINDOW_MS={{ librechat_mcp_cb_cycle_window_ms }}{% endif %}
{% if librechat_mcp_cb_cycle_cooldown_ms is not none %}MCP_CB_CYCLE_COOLDOWN_MS={{ librechat_mcp_cb_cycle_cooldown_ms }}{% endif %}
{% if librechat_mcp_cb_max_failed_rounds is not none %}MCP_CB_MAX_FAILED_ROUNDS={{ librechat_mcp_cb_max_failed_rounds }}{% endif %}
{% if librechat_mcp_cb_failed_window_ms is not none %}MCP_CB_FAILED_WINDOW_MS={{ librechat_mcp_cb_failed_window_ms }}{% endif %}
{% if librechat_mcp_cb_base_backoff_ms is not none %}MCP_CB_BASE_BACKOFF_MS={{ librechat_mcp_cb_base_backoff_ms }}{% endif %}
{% if librechat_mcp_cb_max_backoff_ms is not none %}MCP_CB_MAX_BACKOFF_MS={{ librechat_mcp_cb_max_backoff_ms }}{% endif %}

