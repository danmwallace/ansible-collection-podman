DOMAIN_CLIENT=https://{{ librechat_hostname }}
DOMAIN_SERVER=https://{{ librechat_hostname }}

NO_INDEX={{ librechat_no_index }}

# Reverse-proxy hop count. Express trusts the Nth hop from req.socket.remoteAddress.
TRUST_PROXY={{ librechat_trust_proxy }}

